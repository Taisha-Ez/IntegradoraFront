<Page x:Class="Proyecto_Integradora.Views.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:Proyecto_Integradora.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Login">

    <Page.DataContext>
        <vm:LoginViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="15" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="15" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="Black">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="700" Height="600" Canvas.Right="-150" Canvas.Top="-100">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5">
                        <GradientStop Color="#66FF0000" Offset="0"/>
                        <GradientStop Color="#22990000" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="600" Height="500" Canvas.Left="-200" Canvas.Bottom="-100">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5">
                        <GradientStop Color="#55D32F2F" Offset="0"/>
                        <GradientStop Color="#1A8B0000" Offset="0.6"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="2" Height="2" Canvas.Left="150" Canvas.Top="80" Fill="White"/>
            <Ellipse Width="3" Height="3" Canvas.Left="650" Canvas.Top="380" Fill="#BBFFFFFF"/>
            <Ellipse Width="4" Height="4" Canvas.Left="100" Canvas.Top="350" Fill="#44FF0000"/>
        </Canvas>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="pack://application:,,,/Core/fenix_logo.png" Margin="60" Stretch="Uniform"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,60,0">
                <TextBlock Text="BIENVENIDO" Foreground="White" FontSize="28" FontFamily="Segoe UI Black" Margin="0,0,0,30" HorizontalAlignment="Left"/>

                <Label Content="Usuario" Foreground="#AAA" FontSize="14" FontFamily="Segoe UI Semibold" Margin="0,0,0,5"/>
                <TextBox Style="{StaticResource RoundedTextBox}" 
                         Text="{Binding Usuario, UpdateSourceTrigger=PropertyChanged}" 
                         Height="35" Margin="0,0,0,20"/>

                <Label Content="Contraseña" Foreground="#AAA" FontSize="14" FontFamily="Segoe UI Semibold" Margin="0,0,0,5"/>

                <TextBox Style="{StaticResource RoundedTextBox}" 
                         Text="{Binding Contrasenia, UpdateSourceTrigger=PropertyChanged}"
                         Height="35" Margin="0,0,0,30"/>

                <Button Content="Iniciar Sesión" 
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}" 
                        Height="40" 
                        FontSize="16" 
                        Cursor="Hand"/>

                <TextBlock Margin="0,20,0,0" HorizontalAlignment="Center" Cursor="Hand">
                    <TextBlock.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding IrARegistroCommand}" />
                    </TextBlock.InputBindings>
    
    <Run Text="¿No tienes cuenta?" Foreground="#888" FontSize="13"/>
    <Run Text=" Regístrate" Foreground="White" FontWeight="Bold" FontSize="13"/>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Page>