<Page x:Class="Proyecto_Integradora.Views.SolicitarCreditoView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="900"
      Title="Solicitud de Crédito Fénix" Background="Black">

    <Page.Resources>
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="15" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="10,0"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="15" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Efectos Visuales de Fondo -->
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="600" Height="500" Canvas.Right="-100" Canvas.Top="-50">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#55FF0000" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="2" Height="2" Canvas.Left="150" Canvas.Top="80" Fill="White"/>
            <Ellipse Width="3" Height="3" Canvas.Left="450" Canvas.Top="380" Fill="#88FFFFFF"/>
        </Canvas>

        <Grid Margin="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Lado Izquierdo: Logo -->
            <Image Grid.Column="0" Source="pack://application:,,,/Core/fenix_logo.png" Opacity="0.8" Margin="40"/>

            <!-- Lado Derecho: Formulario Multi-paso -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="40,0">

                <TextBlock x:Name="lblPaso" Text="PASO 1 DE 4" Foreground="#D32F2F" FontSize="12" FontWeight="Bold"/>
                <TextBlock x:Name="lblTituloPaso" Text="SOLICITUD DE CRÉDITO" Foreground="White" FontSize="26" FontFamily="Segoe UI Black" Margin="0,0,0,20"/>

                <ProgressBar x:Name="pgBar" Height="4" Minimum="1" Maximum="4" Value="1" 
                             Background="#1A1A1A" Foreground="#D32F2F" BorderThickness="0" Margin="0,0,0,20"/>

                <Grid>
                    <!-- Paso 1 -->
                    <StackPanel x:Name="Step1" Visibility="Visible">
                        <Label Content="Nombre Completo" Foreground="#AAA" Margin="0,0,0,2"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" x:Name="txtNombre" Height="32" Margin="0,0,0,10"/>
                        <Label Content="CURP / RFC" Foreground="#AAA"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" x:Name="txtRFC" Height="32" CharacterCasing="Upper"/>
                    </StackPanel>

                    <!-- Paso 2 -->
                    <StackPanel x:Name="Step2" Visibility="Collapsed">
                        <Label Content="Dirección" Foreground="#AAA"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" x:Name="txtDireccion" Height="60" TextWrapping="Wrap"/>
                        <Label Content="Teléfono" Foreground="#AAA" Margin="0,10,0,0"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" x:Name="txtTel" Height="32"/>
                    </StackPanel>

                    <!-- Paso 3 -->
                    <StackPanel x:Name="Step3" Visibility="Collapsed">
                        <Label Content="Ingresos Mensuales" Foreground="#AAA"/>
                        <TextBox x:Name="txtIngresos" Style="{StaticResource RoundedTextBox}" Height="32"/>
                    </StackPanel>

                    <!-- Paso 4 -->
                    <StackPanel x:Name="Step4" Visibility="Collapsed">
                        <!-- Referencia 1 -->
                        <TextBlock Text="Referencia Familiar 1" Foreground="#D32F2F" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>

                        <Label Content="Nombre Completo" Foreground="#AAA" Margin="0,0,0,0" FontSize="12"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" x:Name="txtRefNombre1" Height="32" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Label Content="Parentesco" Foreground="#AAA" Margin="0,0,0,0" FontSize="12"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" x:Name="txtRefParentesco1" Height="32"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Label Content="Teléfono" Foreground="#AAA" Margin="0,0,0,0" FontSize="12"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" x:Name="txtRefTel1" Height="32"/>
                            </StackPanel>
                        </Grid>

                        <Separator Background="#222" Margin="0,0,0,12"/>

                        <!-- Referencia 2 -->
                        <TextBlock Text="Referencia Familiar 2" Foreground="#D32F2F" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>

                        <Label Content="Nombre Completo" Foreground="#AAA" Margin="0,0,0,0" FontSize="12"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" x:Name="txtRefNombre2" Height="32" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Label Content="Parentesco" Foreground="#AAA" Margin="0,0,0,0" FontSize="12"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" x:Name="txtRefParentesco2" Height="32"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Label Content="Teléfono" Foreground="#AAA" Margin="0,0,0,0" FontSize="12"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" x:Name="txtRefTel2" Height="32"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Botones de Navegación Inferior -->
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnBack" Grid.Column="0" Content="Regresar" Height="38" 
                            Background="#333" Foreground="White" Click="BtnBack_Click" Visibility="Hidden">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="15" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnNext" Grid.Column="2" Content="Siguiente" 
                            Style="{StaticResource PrimaryButton}" Height="38" Click="BtnNext_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
