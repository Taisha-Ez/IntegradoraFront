<Page x:Class="Proyecto_Integradora.Views.ValesExpedidosView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Proyecto_Integradora.Views"
      xmlns:vm="clr-namespace:Proyecto_Integradora.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="ValesExpedidosView"
      FontFamily="Segoe UI">

    <Page.DataContext>
        <vm:ValesExpedidosViewModel/>
    </Page.DataContext>


    <Page.Resources>
        <Style x:Key="NavbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0,0,0,4"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="25,10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="Red"/>
                                <Setter Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchButtonStyle" TargetType="Button" BasedOn="{StaticResource NavbarButtonStyle}">
            <Setter Property="Foreground" Value="#FF4D4D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <StackPanel Orientation="Horizontal" Margin="25,10">
                                <TextBlock Text="🔍" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="14"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="Red"/>
                                <Setter Property="Background" Value="#20FF0000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#050505" BorderBrush="#111" BorderThickness="0,0,1,0">
            <StackPanel>
                <Image Source="/Core/fenix logo.png" 
                       Height="70" Width="70" 
                       Margin="0,30,0,0" 
                       Opacity="0.8"
                       Stretch="Uniform"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#0A0A0A">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Image Grid.Row="1" Source="pack://application:,,,/Core/fenix_logo.png" 
                   Opacity="0.15" 
                   Stretch="Uniform" 
                   Margin="80"/>

            <Border Grid.Row="0" Background="#0D0D0D" BorderBrush="#111" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="TODOS" Command="{Binding VerTodosCommand}" Style="{StaticResource NavbarButtonStyle}"/>
                        <Button Content="ACEPTADOS" Command="{Binding VerAceptadosCommand}" Style="{StaticResource NavbarButtonStyle}"/>
                        <Button Content="RECHAZADOS" Command="{Binding VerRechazadosCommand}" Style="{StaticResource NavbarButtonStyle}"/>
                    </StackPanel>

                    <Button Content="BUSCAR" 
                            Style="{StaticResource SearchButtonStyle}" 
                            HorizontalAlignment="Right" 
                            Margin="0,0,20,0"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="30">
                <DataGrid ItemsSource="{Binding Vales}" 
                  AutoGenerateColumns="False" 
                  Background="Transparent" 
                  Foreground="White" 
                  BorderThickness="0"
                  GridLinesVisibility="None"
                  IsReadOnly="True"
                  RowBackground="#0D0D0D"
                  AlternatingRowBackground="#121212">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#111111"/>
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderBrush" Value="#222222"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Usuario" Binding="{Binding usuario}" Width="100"/>
                        <DataGridTextColumn Header="Nombre Completo" Width="*">
                            <DataGridTextColumn.Binding>
                                <MultiBinding StringFormat="{}{0} {1} {2}">
                                    <Binding Path="nombre"/>
                                    <Binding Path="apellidoPaterno"/>
                                    <Binding Path="apellidoMaterno"/>
                                </MultiBinding>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Monto" Binding="{Binding montoSolicitado, StringFormat=C}" Width="120"/>
                        <DataGridTextColumn Header="Plazo" Binding="{Binding plazoPagoMeses, StringFormat='\{0\} Meses'}" Width="100"/>
                        <DataGridTextColumn Header="Estado" Binding="{Binding status}" Width="120"/>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding createdAt, StringFormat=d}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Page>