<Page x:Class="Proyecto_Integradora.Views.AdminInicioView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:Proyecto_Integradora.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="AdminInicioView">

    <Page.DataContext>
        <vm:AdminInicioViewModel/>
    </Page.DataContext>
    
    <Page.Resources>
        <Style x:Key="BotonResaltadoRojo" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="CuerpoBoton" Background="{TemplateBinding Background}" Margin="0,2">
                            <Grid>
                                <!-- Barra roja lateral (solo visible cuando se selecciona) -->
                                <Rectangle x:Name="BarraRoja" 
                                   Fill="#FF0000" 
                                   Width="4" 
                                   HorizontalAlignment="Left" 
                                   Visibility="Hidden">
                                    <Rectangle.Effect>
                                        <DropShadowEffect Color="Red" BlurRadius="10" ShadowDepth="0"/>
                                    </Rectangle.Effect>
                                </Rectangle>

                                <ContentPresenter VerticalAlignment="Center" Margin="30,0,0,0"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- 1. ILUMINACIÓN AL PASAR EL MOUSE (Hover) -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="CuerpoBoton" Property="Background" Value="#151515"/>
                            </Trigger>

                            <!-- 2. ILUMINACIÓN ESTÁTICA AL HACER CLIC (Checked) -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="BarraRoja" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CuerpoBoton" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush EndPoint="1,0.5" StartPoint="0,0.5">
                                            <GradientStop Color="#40FF0000" Offset="0"/>
                                            <GradientStop Color="Transparent" Offset="0.7"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <Border Grid.Column="0" Background="#050505" BorderBrush="#111" BorderThickness="0,0,1,0">
            <StackPanel>
                <Image Source="pack://application:,,,/Core/fenix_logo.png" Height="120" Margin="0,40,0,40"/>

                <TextBlock Text="ADMINISTRACIÓN" Foreground="#444" Margin="25,0,0,15" FontSize="10" FontWeight="Bold"/>

                <RadioButton Content="CLIENTES" 
                 GroupName="MenuAdmin"
                 Style="{StaticResource BotonResaltadoRojo}" 
                 Click="NavegarClientes_Click"/>

                <RadioButton Content="VALES EXPEDIDOS" 
                 GroupName="MenuAdmin"
                 Style="{StaticResource BotonResaltadoRojo}" 
                 Click="NavegarVales_Click"/>

                <RadioButton Content="INGRESOS / EGRESOS" 
                 GroupName="MenuAdmin"
                 Style="{StaticResource BotonResaltadoRojo}" 
                 Click="NavegarIngresos_Click"/>

                <RadioButton Content="REVISIÓN" 
                 GroupName="MenuAdmin"
                 Style="{StaticResource BotonResaltadoRojo}" 
                 Click="NavegarRevision_Click"/>

                <RadioButton Content="CERRAR SESIÓN" 
                 Command="{Binding RegresarCommand}"
                 Style="{StaticResource BotonResaltadoRojo}"
                 Margin="0,30,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#0A0A0A">
            <!-- Este Frame es el que cargará tus páginas -->
            <Frame x:Name="AdminContentFrame" 
           NavigationUIVisibility="Hidden" />

            <!-- Este es el contenido que se muestra por defecto (opcional) -->
            <StackPanel x:Name="DefaultContent" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="pack://application:,,,/Core/fenix_logo.png" Opacity="0.15" Stretch="Uniform" Margin="100"/>
                <TextBlock Text="FENIX SYSTEM" Foreground="White" FontSize="40" FontWeight="Thin" HorizontalAlignment="Center"/>
                <Border Background="Red" Height="2" Width="50" Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>