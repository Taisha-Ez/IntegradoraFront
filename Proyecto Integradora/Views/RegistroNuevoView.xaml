<Page x:Class="Proyecto_Integradora.Views.RegistroNuevoView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Proyecto_Integradora.Views"
      xmlns:vm="clr-namespace:Proyecto_Integradora.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Registro">

    <Page.DataContext>
        <vm:RegistroViewModel/>
    </Page.DataContext>
    
    <Page.Resources>
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="15" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="15" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="15" Background="{TemplateBinding Background}" BorderBrush="#555" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border CornerRadius="15"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordToggleButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}"/>
    </Page.Resources>

    <Grid Background="Black">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="700" Height="600" Canvas.Right="-150" Canvas.Top="-100">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5">
                        <GradientStop Color="#66FF0000" Offset="0"/>
                        <GradientStop Color="#22990000" Offset="0.5"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="600" Height="500" Canvas.Left="-200" Canvas.Bottom="-100">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5">
                        <GradientStop Color="#55D32F2F" Offset="0"/>
                        <GradientStop Color="#1A8B0000" Offset="0.6"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="450" Height="450" Canvas.Left="180" Canvas.Top="0">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5">
                        <GradientStop Color="#15FFFFFF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="0.8"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="2" Height="2" Canvas.Left="150" Canvas.Top="80" Fill="#FFFFFFFF"/>
            <Ellipse Width="3" Height="3" Canvas.Left="650" Canvas.Top="380" Fill="#BBFFFFFF"/>
            <Ellipse Width="2" Height="2" Canvas.Left="450" Canvas.Top="50" Fill="#88FFFFFF"/>
            <Ellipse Width="4" Height="4" Canvas.Left="100" Canvas.Top="350" Fill="#44FF0000"/>
            <Ellipse Width="2" Height="2" Canvas.Left="750" Canvas.Top="150" Fill="#66FF0000"/>
        </Canvas>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="60,0,0,0">

                <TextBlock Text="REGISTRO" Foreground="White" FontSize="26" FontFamily="Segoe UI Black" Margin="0,0,0,15" HorizontalAlignment="Left"/>

                <Label Content="Nombre(s)" Foreground="#AAA" FontSize="13" FontFamily="Segoe UI Semibold" Margin="0,0,0,2" Padding="0"/>
                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Nombre}" Height="32" Margin="0,0,0,10"/>

                <Label Content="Apellido Paterno" Foreground="#AAA" FontSize="13" FontFamily="Segoe UI Semibold" Margin="0,0,0,2" Padding="0"/>
                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ApellidoP}" Height="32" Margin="0,0,0,10"/>

                <Label Content="Apellido Materno" Foreground="#AAA" FontSize="13" FontFamily="Segoe UI Semibold" Margin="0,0,0,2" Padding="0"/>
                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ApellidoM}"  Height="32" Margin="0,0,0,10"/>

                <Label Content="Usuario" Foreground="#AAA" FontSize="13" FontFamily="Segoe UI Semibold" Margin="0,0,0,2" Padding="0"/>
                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Usuario}" Height="32" Margin="0,0,0,10"/>

                <Label Content="Contraseña" Foreground="#AAA" FontSize="13" FontFamily="Segoe UI Semibold" Margin="0,0,0,2" Padding="0"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <PasswordBox x:Name="txtPassword"
                                     Style="{StaticResource RoundedPasswordBox}"
                                     PasswordChanged="txtPassword_PasswordChanged"
                                     Height="32"
                                     Visibility="Visible">
                        </PasswordBox>

                        <TextBox x:Name="txtPasswordVisible"
                                 Style="{StaticResource RoundedTextBox}"
                                 Height="32"
                                 Visibility="Collapsed"
                                 TextChanged="txtPasswordVisible_TextChanged"/>
                    </Grid>

                    <Button x:Name="btnTogglePassword"
                            Grid.Column="1"
                            Content="Mostrar"
                            Margin="10,0,0,0"
                            Height="32"
                            Style="{StaticResource PasswordToggleButton}"
                            Click="TogglePasswordVisibility_Click"
                            Cursor="Hand"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Confirmar" Command="{Binding ConfirmarCommand}" Style="{StaticResource PrimaryButton}" Height="38" FontSize="15" Cursor="Hand"/>
                    <Button Grid.Column="2" Content="Regresar" Command="{Binding RegresarCommand}" Style="{StaticResource SecondaryButton}" Height="38" FontSize="15" Cursor="Hand"/>
                </Grid>

            </StackPanel>

            <Image Grid.Column="1" Source="pack://application:,,,/Core/fenix_logo.png" Margin="60" Stretch="Uniform"/>

        </Grid>
    </Grid>
</Page>
