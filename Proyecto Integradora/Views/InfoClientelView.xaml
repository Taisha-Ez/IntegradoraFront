<Page x:Class="Proyecto_Integradora.Views.ClientePantallaPrinicipalView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Proyecto_Integradora.Views"
      xmlns:vm="clr-namespace:Proyecto_Integradora.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="ClientePantallaPrinicipalView"
      FontFamily="Segoe UI">

    <Page.DataContext>
        <vm:InfoClienteViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <Style x:Key="NavbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="30,15"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,4"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="Red"/>
                                <Setter Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DarkGridCell" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#F2F2F2"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#050505" BorderBrush="#111" BorderThickness="0,0,1,0">
            <StackPanel>
                <Image Source="/Core/fenix logo.png" 
                       Height="70" 
                       Width="70" 
                       Margin="0,30,0,0" 
                       Opacity="0.8"
                       Stretch="Uniform"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#0A0A0A">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Image Grid.Row="1" Source="pack://application:,,,/Core/fenix_logo.png" 
                   Opacity="0.15" 
                   Stretch="Uniform" 
                   Margin="80"/>

            <Border Grid.Row="0" Background="#0D0D0D" BorderBrush="#111" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="TODOS" 
            Command="{Binding CargarTodosCommand}" 
            Style="{StaticResource NavbarButtonStyle}"/>

                    <Button Content="CUMPLIDOS" 
            Command="{Binding CargarCumplidosCommand}" 
            Style="{StaticResource NavbarButtonStyle}"/>

                    <Button Content="MOROSOS" 
            Command="{Binding CargarMorososCommand}" 
            Style="{StaticResource NavbarButtonStyle}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="30">
                <DataGrid ItemsSource="{Binding Clientes}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          Background="Transparent"
                          Foreground="White"
                          BorderThickness="0"
                          GridLinesVisibility="None"
                          RowBackground="#101010"
                          AlternatingRowBackground="#151515"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DarkGridColumnHeader}"/>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource DarkGridCell}"/>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Usuario" Binding="{Binding usuario}" Width="120"/>
                        <DataGridTextColumn Header="Nombre Completo" Binding="{Binding nombreCompleto}" Width="*"/>
                        <DataGridTextColumn Header="CURP / RFC" Binding="{Binding curpRfc}" Width="170"/>
                        <DataGridTextColumn Header="Ingreso Mensual" Binding="{Binding monthlyIncome, StringFormat=C}" Width="120"/>
                        <DataGridTextColumn Header="Crédito Estimado" Binding="{Binding estimatedCredit, StringFormat=C}" Width="130"/>
                        <DataGridTextColumn Header="Estado" Binding="{Binding status}" Width="100"/>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding createdAt, StringFormat=d}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</Page>