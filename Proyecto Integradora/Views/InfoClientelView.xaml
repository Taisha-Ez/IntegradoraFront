<Page x:Class="Proyecto_Integradora.Views.ClientePantallaPrinicipalView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Proyecto_Integradora.Views"
      xmlns:vm="clr-namespace:Proyecto_Integradora.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="ClientePantallaPrinicipalView"
      FontFamily="Segoe UI">

    <Page.DataContext>
        <vm:InfoClienteViewModel/>
    </Page.DataContext>

    <Page.Resources>
        <Style x:Key="NavbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="30,15"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,4"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="Red"/>
                                <Setter Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkGridColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DarkGridCell" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#F2F2F2"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="ClientCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#131313"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="BorderBrush" Value="#242424"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="360"/>
            <Setter Property="Height" Value="220"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
    </Page.Resources>

    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#050505" BorderBrush="#111" BorderThickness="0,0,1,0">
            <StackPanel>
                <Image Source="/Core/fenix logo.png" 
                       Height="70" 
                       Width="70" 
                       Margin="0,30,0,0" 
                       Opacity="0.8"
                       Stretch="Uniform"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#0A0A0A">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Image Grid.Row="1" Source="pack://application:,,,/Core/fenix_logo.png" 
                   Opacity="0.15" 
                   Stretch="Uniform" 
                   Margin="80"/>

            <Border Grid.Row="0" Background="#0D0D0D" BorderBrush="#111" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="CLIENTES CON CRÉDITO SOLICITADO"
                               Foreground="#F2F2F2"
                               FontSize="12"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="30,0,0,0"/>

                    <Button Content="RECARGAR"
                            Command="{Binding RecargarCommand}"
                            Style="{StaticResource NavbarButtonStyle}"
                            HorizontalAlignment="Right"
                            Margin="0,0,20,0"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="30,24,30,30">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Clientes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemHeight="220" ItemWidth="360"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ClientCardStyle}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.25" Color="Black"/>
                                    </Border.Effect>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding nombreCompleto}"
                                                           Foreground="White"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="@{Binding usuario}"
                                                           Foreground="#A0A0A0"
                                                           FontSize="12"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <Border Grid.Column="1"
                                                    Background="#1E1E1E"
                                                    BorderBrush="#333"
                                                    BorderThickness="1"
                                                    CornerRadius="999"
                                                    Padding="12,4"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding status}"
                                                           Foreground="#FF5A5A"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding curpRfc}"
                                                   Foreground="#DDDDDD"
                                                   FontSize="12"
                                                   Margin="0,8,0,0"/>

                                        <StackPanel Grid.Row="2" Margin="0,18,0,0">
                                            <TextBlock>
                                                <Run Text="Ingreso mensual: " Foreground="#888"/>
                                                <Run Text="{Binding monthlyIncome, StringFormat=C}" Foreground="White" FontWeight="SemiBold"/>
                                            </TextBlock>
                                            <TextBlock Margin="0,10,0,0">
                                                <Run Text="Crédito estimado: " Foreground="#888"/>
                                                <Run Text="{Binding estimatedCredit, StringFormat=C}" Foreground="#FFFFFF" FontWeight="Bold"/>
                                            </TextBlock>
                                            <TextBlock Margin="0,10,0,0">
                                                <Run Text="Tipo de usuario: " Foreground="#888"/>
                                                <Run Text="{Binding tipoUsuario}" Foreground="#FFFFFF"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Row="3"
                                                   Text="{Binding createdAt, StringFormat=Solicitud: {0:d}}"
                                                   Foreground="#777"
                                                   FontSize="11"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,12,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>